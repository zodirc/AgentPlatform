# Agent Platform — 起栈环境变量（Bootstrap）
# cp .env.example .env
# 模型 API key / URL / 模型名 → Web「设置 → 模型」（ADR-019）；本文件只做起栈。
# 默认已是 live + pgvector + 本地 embedding。高级旋钮见 docs/03 附录 A。
# CI 可临时覆盖，例如 MODEL_MODE=stub

# --- 网络 / 网关 ---
PUBLIC_DOMAIN=localhost          # 浏览器访问主机名
HOST_PORT=443                    # 宿主机 HTTPS → gateway
HTTP_PORT=80                     # 宿主机 HTTP → gateway（本地常用）

# --- PostgreSQL ---
POSTGRES_USER=agent              # 数据库用户
POSTGRES_PASSWORD=agent          # 数据库密码（生产必改）
POSTGRES_DB=agent                # 数据库名
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent  # 容器内连接串（主机名用 postgres）

# --- 安全（生产必改 change-me / 默认口令）---
APP_SECRET_KEY=change-me-in-production   # Session 签名；兼派生模型配置加密密钥
INTERNAL_SERVICE_TOKEN=change-me-internal # api→runtime 内部鉴权（须一致）
AUTH_ENABLED=true                        # 是否启用登录
ADMIN_PASSWORD=admin                     # 管理端初始口令
END_USER_AUTH_ENABLED=true               # 终端用户登录（会话归属）
ADMIN_SESSION_BYPASS=true                # 管理会话旁路（本地方便；生产建议 false）
END_USER_COOKIE_SECURE=false             # Cookie 仅 HTTPS（公网 HTTPS 改为 true）
# CONFIG_ENCRYPTION_KEY=                 # 可选；模型配置专用加密密钥

# --- 工作区 ---
WORKSPACE_ROOT=/workspace        # 容器内默认/遗留沙箱根；Work.work_root 可认领或指向 /data/works/{id}
# WORKS_ROOT=/data/works         # 新建默认 Work 的隔离根（docs/27）
# WORKS_CLAIM_LEGACY_WORKSPACE=true  # 仅第一个默认 Work 可认领 WORKSPACE_ROOT
WORKSPACE_HOST_PATH=../workspace # 宿主机目录挂载进容器

# --- 运行环境 ---
APP_ENV=production               # production | development
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# --- 模型（可选 fallback；主路径是 Web 设置）---
# MODEL_MODE=live                # live=真调用；stub=契约/golden
# MODEL_API_KEY=                 # 无 Web profile 时的 fallback key
# MODEL_PROVIDER=anthropic       # 与 key 匹配的供应商
# MODEL_NAME=                    # 空=代码默认模型名
# ANTHROPIC_BASE_URL=            # Anthropic 兼容代理
# OPENAI_BASE_URL=               # OpenAI 兼容代理

# --- 种子资料（可选；不填用 compose 默认）---
# SEED_SOURCES_HOST_PATH=./seed/sources/writing  # 宿主机种子目录
# SEED_SOURCES_ROOT=/workspace/sources/seed/writing  # 容器内只读挂载点
