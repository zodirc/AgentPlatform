# Agent Platform — 环境变量模板
# 使用: cp .env.example .env 后按需修改

# --- 网络 / 网关 ---
PUBLIC_DOMAIN=localhost
HOST_PORT=443
HTTP_PORT=80

# --- PostgreSQL ---
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent
DATABASE_URL=postgresql://agent:agent@postgres:5432/agent

# --- 安全 ---
APP_SECRET_KEY=change-me-in-production
AUTH_ENABLED=true
ADMIN_PASSWORD=admin
INTERNAL_SERVICE_TOKEN=change-me-internal

# --- 模型（runtime 服务）---
# Bootstrap fallback：DB 无激活 profile 时使用（ADR-019）。Phase 1 起优先在 Web 设置页配置，无需重启。
MODEL_PROVIDER=anthropic
MODEL_NAME=
MODEL_API_KEY=
MODEL_MODE=stub
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# 可选：专用配置加密密钥；省略时由 APP_SECRET_KEY 派生（api 加密 / runtime 解密）
# CONFIG_ENCRYPTION_KEY=

# --- 工作区（runtime 工具沙箱，见 docs/03-docker-runtime.md §8）---
WORKSPACE_ROOT=/workspace
WORKSPACE_HOST_PATH=../workspace

# --- 运行环境 ---
APP_ENV=production
LOG_LEVEL=INFO

# --- 可观测性（Phase 4，默认关闭；设 OTEL_ENABLED=true 启用控制台 span 导出）---
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# --- runtime 工具与配额 ---
RUN_COMMAND_MODE=shell
TURN_TOKEN_BUDGET=0
MONTHLY_TOKEN_LIMIT=0
MONTHLY_TOKEN_ALERT_PCT=0.8
# Model context window (provider limit) and compaction thresholds.
CONTEXT_WINDOW_TOKENS=128000
# Tokens reserved for model output when computing fill ratio.
CONTEXT_OUTPUT_RESERVE_TOKENS=16384
# Pressure thresholds (0–1): collapse / snip / autocompact.
CONTEXT_FILL_COLLAPSE=0.75
CONTEXT_FILL_SNIP=0.85
CONTEXT_FILL_AUTOCOMPACT=0.95
# Hot-zone fraction of working message budget kept verbatim during collapse.
CONTEXT_HOT_ZONE_RATIO=0.35

# --- 异步 worker（配合 deploy/compose/queue.yml --profile queue）---
# WORKER_MODE=outbox
# INDEX_VIA_WORKER=true

# --- 检索 / embedding（配合 deploy/compose/retrieval.yml --profile retrieval）---
# RETRIEVAL_MODE=hybrid          # keyword | vector | hybrid（默认 hybrid）
# RETRIEVAL_RRF_K=60
# RETRIEVAL_RERANK_ENABLED=true
# RETRIEVAL_RERANK_CROSS_ENCODER=false
# RETRIEVAL_RERANK_MODEL=BAAI/bge-reranker-base
# SEARCH_SOURCES_MAX_PER_TURN=3
# SEARCH_SOURCES_EXCERPT_CHARS=200
# Writing material cards (pinned into writing turns; not RAG-indexed)
# WRITING_CARDS_DIR=sources/cards
# WRITING_CARDS_MAX_CHARS=2000
# WRITING_CARDS_PER_CARD_CHARS=800
# retrieval 镜像默认：构建期烘焙模型 → 启动时同步至 /data/models
# EMBEDDING_BACKEND=sentence_transformers
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_MODEL_DIR=/data/models
# 无 retrieval 镜像时可用 hash（仅开发/降级）：
# EMBEDDING_BACKEND=hash
# EMBEDDING_DIMENSIONS=256

# --- 多 runtime 副本（配合 deploy/compose/ha.yml，make up-ha）---
# RUNTIME_URL=http://runtime-a:8001
# RUNTIME_URL_MAP={"runtime-a":"http://runtime-a:8001","runtime-b":"http://runtime-b:8001"}
# RUNTIME_RUNNER_ID=runtime-a   # 每个 runtime 容器单独设置
