# Local dev: mount source + uvicorn --reload (copy to dev.override.yml; not used in CI).
services:
  api:
    volumes:
      - ../../services/api/app:/app/app:ro
    environment:
      APP_ENV: development
    command:
      [
        "uvicorn",
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload",
      ]
  runtime:
    volumes:
      - ../../services/runtime/app:/app/app:ro
    environment:
      APP_ENV: development
    command:
      [
        "uvicorn",
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001",
        "--reload",
      ]
