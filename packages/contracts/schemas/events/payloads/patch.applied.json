{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-platform.local/schemas/events/payloads/patch.applied.json",
  "title": "PatchAppliedPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["patch_id", "path", "status"],
  "properties": {
    "patch_id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["applied"] },
    "bytes_written": { "type": "integer", "minimum": 0 },
    "auto_applied": {
      "type": "boolean",
      "description": "True when writing mode auto-applied propose_patch without UI Accept"
    }
  }
}
