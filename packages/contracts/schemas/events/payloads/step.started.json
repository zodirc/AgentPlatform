{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-platform.local/schemas/events/payloads/step.started.json",
  "title": "StepStartedPayload",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "step_index": {
      "type": "integer",
      "minimum": 0
    },
    "label": {
      "type": "string",
      "maxLength": 128
    },
    "subagent_id": {
      "type": "string",
      "minLength": 1,
      "description": "Present when the event originates from a nested delegate sub-agent."
    }
  }
}
