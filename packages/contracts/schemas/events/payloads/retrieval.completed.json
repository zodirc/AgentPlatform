{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-platform.local/schemas/events/payloads/retrieval.completed.json",
  "title": "RetrievalCompletedPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["query", "mode", "hit_count"],
  "properties": {
    "query": { "type": "string", "maxLength": 4096 },
    "mode": {
      "type": "string",
      "enum": ["vector", "keyword", "hybrid", "none"]
    },
    "hit_count": { "type": "integer", "minimum": 0 },
    "index": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": { "type": "string", "maxLength": 512 },
    "filters": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path_prefix": { "type": "string" },
        "applied": { "type": "boolean" },
        "error": { "type": "string" }
      }
    },
    "hits": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path": { "type": "string" },
          "chunk_id": { "type": "string" },
          "excerpt": { "type": "string", "maxLength": 512 },
          "citation_id": { "type": "string" },
          "score": { "type": "number" }
        }
      }
    }
  }
}
