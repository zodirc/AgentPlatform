{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-platform.local/schemas/events/payloads/patch.proposed.json",
  "title": "PatchProposedPayload",
  "type": "object",
  "additionalProperties": false,
  "required": ["patch_id", "path", "status"],
  "properties": {
    "patch_id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "old_text": { "type": "string", "maxLength": 65536 },
    "new_text": { "type": "string", "maxLength": 65536 },
    "summary": { "type": "string", "maxLength": 4096 },
    "status": { "type": "string", "enum": ["pending"] }
  }
}
