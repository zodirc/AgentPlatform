{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-platform.local/schemas/events/payloads/context.reported.json",
  "title": "ContextReportedPayload",
  "description": "Per-step context window occupancy after ContextEngine.assemble",
  "type": "object",
  "additionalProperties": false,
  "required": ["step_index", "tokens_after", "token_budget"],
  "properties": {
    "step_index": { "type": "integer", "minimum": 0 },
    "tokens_before": { "type": "integer", "minimum": 0 },
    "tokens_after": { "type": "integer", "minimum": 0 },
    "token_budget": { "type": "integer", "minimum": 0 },
    "reserve_tokens": { "type": "integer", "minimum": 0 },
    "fill_ratio": { "type": "number", "minimum": 0 },
    "system_tokens": { "type": "integer", "minimum": 0 },
    "tools_tokens": { "type": "integer", "minimum": 0 },
    "messages_tokens": { "type": "integer", "minimum": 0 },
    "project_tokens": { "type": "integer", "minimum": 0 },
    "runtime_tokens": { "type": "integer", "minimum": 0 },
    "assemble_ms": { "type": "number", "minimum": 0 },
    "source": { "type": "string", "enum": ["estimated", "provider"] },
    "strategies": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 16
    },
    "breakdown": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "system": { "type": "integer", "minimum": 0 },
        "tools": { "type": "integer", "minimum": 0 },
        "session": { "type": "integer", "minimum": 0 },
        "user": { "type": "integer", "minimum": 0 },
        "assistant": { "type": "integer", "minimum": 0 },
        "tool_results": { "type": "integer", "minimum": 0 },
        "compaction": { "type": "integer", "minimum": 0 },
        "project": { "type": "integer", "minimum": 0 },
        "runtime": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
